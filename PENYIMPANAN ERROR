-- Function to Select Tab
function SelectTab(tabName)
    if SelectedTab == tabName then return end
    
    local isSmall = isMobile
    
    -- Deselect previous tab
    if SelectedTab and TabButtons[SelectedTab] then
        local prev = TabButtons[SelectedTab]
        TweenObject(prev.Button, {BackgroundColor3 = COLORS.Secondary}, 0.2)
        TweenObject(prev.Icon, {TextColor3 = COLORS.TextDim}, 0.2)
        TweenObject(prev.Label, {TextColor3 = COLORS.TextDim}, 0.2)
        TweenObject(prev.Indicator, {Size = UDim2.new(0, isSmall and 2.5 or 3, 0, 0)}, 0.3)
    end
    
    -- Select new tab
    SelectedTab = tabName
    local current = TabButtons[tabName]
    TweenObject(current.Button, {BackgroundColor3 = Color3.fromRGB(35, 35, 45)}, 0.2)
    TweenObject(current.Icon, {TextColor3 = COLORS.Accent}, 0.2)
    TweenObject(current.Label, {TextColor3 = COLORS.Text}, 0.2)
    TweenObject(current.Indicator, {Size = UDim2.new(0, isSmall and 2.5 or 3, 1, isSmall and -8 or -10)}, 0.3, Enum.EasingStyle.Back)
    
    -- Update content
    UpdateContent(tabName)
end

-- Function to Update Content
function UpdateContent(tabName)
    if tabName == "Visuals" then
        CreateVisualsContent()
    elseif tabName == "Credits" then
        CreateCreditsContent()
    else
        -- Clear existing content
        for _, child in pairs(ContentFrame:GetChildren()) do
            child:Destroy()
        end
        
        local isSmall = isMobile
        
        -- Placeholder content
        local placeholder = Instance.new("TextLabel")
        placeholder.Size = UDim2.new(1, 0, 1, 0)
        placeholder.BackgroundTransparency = 1
        placeholder.Text = tabName .. " Tab\n\nContent will be added here"
        placeholder.Font = Enum.Font.Gotham
        placeholder.TextSize = isSmall and 12 or 16
        placeholder.TextColor3 = COLORS.TextDim
        placeholder.Parent = ContentFrame
    end
end

