        or inp.UserInputType == Enum.UserInputType.Touch then svDrag = false end
    end)

    -- Hue drag
    local hueDrag = false
    local function HandleHue(ax)
        local hx = hueTrack.AbsolutePosition.X
        local hw = hueTrack.AbsoluteSize.X
        curH = math.clamp((ax - hx) / hw, 0, 1)
        ApplyAll()
    end

    hueHit.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            hueDrag = true; HandleHue(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not hueDrag then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            HandleHue(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then hueDrag = false end
    end)

    -- Hex input
    hexBox.FocusLost:Connect(function()
        local hex = hexBox.Text:gsub("#",""):upper()
        if #hex == 6 then
            local r = tonumber(hex:sub(1,2),16) or 0
            local g = tonumber(hex:sub(3,4),16) or 0
            local b = tonumber(hex:sub(5,6),16) or 0
            local c = Color3.fromRGB(r,g,b)
            local mx=math.max(c.R,c.G,c.B); local mn=math.min(c.R,c.G,c.B); local d=mx-mn
            curV=mx; curS= mx==0 and 0 or d/mx
            if d==0 then curH=0 elseif mx==c.R then curH=((c.G-c.B)/d)%6/6
            elseif mx==c.G then curH=((c.B-c.R)/d+2)/6 else curH=((c.R-c.G)/d+4)/6 end
            ApplyAll()
        end
    end)

    -- RGB input
    for i, box in ipairs(rgbBoxes) do
        box.FocusLost:Connect(function()
            local rv = math.clamp(tonumber(rgbBoxes[1].Text) or 0, 0, 255) / 255
            local gv = math.clamp(tonumber(rgbBoxes[2].Text) or 0, 0, 255) / 255
            local bv = math.clamp(tonumber(rgbBoxes[3].Text) or 0, 0, 255) / 255
            local mx=math.max(rv,gv,bv); local mn=math.min(rv,gv,bv); local d=mx-mn
            curV=mx; curS= mx==0 and 0 or d/mx
            if d==0 then curH=0 elseif mx==rv then curH=((gv-bv)/d)%6/6
            elseif mx==gv then curH=((bv-rv)/d+2)/6 else curH=((rv-gv)/d+4)/6 end
            ApplyAll()
        end)
    end

