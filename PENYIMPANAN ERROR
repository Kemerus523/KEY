local function ShowNotification(msg, ok)
    InfoText.Text = msg
    InfoText.TextColor3 = ok and COLORS.Success or COLORS.Error
    if not ok then
        task.wait(2)
        InfoText.Text = "Enter your key to continue"
        InfoText.TextColor3 = COLORS.TextDim
    end
end

SubmitButton.MouseButton1Click:Connect(function()
    local key = KeyInputBox.Text
    if key == "" then ShowNotification("Please enter a key!", false); return end

    if key == CONFIG.ValidKey then
        ShowNotification("Key validated! Loading...", true)
        task.wait(0.5)
        TweenObject(KeyFrame, {Size = UDim2.new(0,0,0,0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3); KeyFrame.Visible = false
        MainFrame.Size = UDim2.new(0,0,0,0)
        MainFrame.Visible = true
        TweenObject(MainFrame, {Size = UDim2.new(0,GW,0,GH)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        task.wait(0.2)
        SelectTab("Combat")
    else
        ShowNotification("Invalid key! Try again.", false)
        KeyInputBox.Text = ""
    end
end)

KeyInputBox.FocusLost:Connect(function(enter)
    if enter then SubmitButton.MouseButton1Click:Fire() end
end)

