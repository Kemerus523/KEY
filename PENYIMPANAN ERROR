    icon.BackgroundTransparency = 1
    icon.Text = tabData.Icon; icon.Font = Enum.Font.GothamBold
    icon.TextSize = 14; icon.TextColor3 = COLORS.TextDim
    icon.Parent = btn

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -36, 1, 0)
    lbl.Position = UDim2.new(0, 32, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = tabData.Name; lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 10; lbl.TextColor3 = COLORS.TextDim
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = btn

    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 2.5, 0, 0)
