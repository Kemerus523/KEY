        local bx = svBox.AbsolutePosition.X
        local by = svBox.AbsolutePosition.Y
        local bw = svBox.AbsoluteSize.X
        local bh = svBox.AbsoluteSize.Y
        curS = math.clamp((ax - bx) / bw, 0, 1)
        curV = 1 - math.clamp((ay - by) / bh, 0, 1)
        ApplyAll()
    end

