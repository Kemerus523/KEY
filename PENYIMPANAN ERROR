-- COMBAT TAB — Auto F dengan custom keybind (mouse / keyboard)
-- =============================================

-- State Auto F
local autoFEnabled   = false   -- apakah loop F sedang berjalan
local isBindingKey   = false   -- sedang mode binding keybind

-- Keybind bisa mouse atau keyboard
-- Tipe: "mouse" atau "keyboard"
local autoFBindType  = "mouse"                          -- default mouse
local autoFMouseBtn  = Enum.UserInputType.MouseButton2  -- default klik kanan
local autoFKeyCode   = Enum.KeyCode.F                   -- dipakai kalau tipe keyboard

-- Label display untuk keybind
local function GetBindLabel()
    if autoFBindType == "mouse" then
        if autoFMouseBtn == Enum.UserInputType.MouseButton1 then
            return "Mouse Kiri"
        elseif autoFMouseBtn == Enum.UserInputType.MouseButton2 then
            return "Mouse Kanan"
        elseif autoFMouseBtn == Enum.UserInputType.MouseButton3 then
            return "Mouse Tengah"
        end
        return "Mouse"
    else
        return autoFKeyCode.Name
    end
end

-- Loop click F
local autoFConn = nil

local function PressF()
    pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendKeyEvent(true,  Enum.KeyCode.F, false, game)
        task.wait(0.05)
        VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
    end)
end

local function StartAutoF()
    if autoFConn then autoFConn:Disconnect() end
    autoFConn = RunService.Heartbeat:Connect(function()
        if not autoFEnabled then return end
        PressF()
        -- Throttle ~10 kali per detik
        task.wait(0.1)
    end)
end

local function StopAutoF()
    autoFEnabled = false
    if autoFConn then autoFConn:Disconnect(); autoFConn = nil end
end

-- Refs UI yang perlu diupdate dari global listener
local _afStatusLbl  = nil
local _afKbBtn      = nil
local _afToggleTrack = nil
local _afCircle     = nil

local function SyncAutoFUI()
    if _afStatusLbl then
        _afStatusLbl.Text = autoFEnabled and "Status: ON — Loop menekan F" or "Status: OFF"
        _afStatusLbl.TextColor3 = autoFEnabled and COLORS.Success or COLORS.TextDim
    end
    if _afToggleTrack and _afCircle then
        TweenObject(_afToggleTrack, {BackgroundColor3 = autoFEnabled and COLORS.Accent or COLORS.Border}, 0.15)
        TweenObject(_afCircle, {Position = autoFEnabled and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)}, 0.15)
    end
end

local function ToggleAutoF()
    autoFEnabled = not autoFEnabled
    if autoFEnabled then
        StartAutoF()
    else
        StopAutoF()
    end
    SyncAutoFUI()
