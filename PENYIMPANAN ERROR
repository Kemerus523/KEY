-- Function to Create Checkbox Toggle (GANTI DARI SWITCH KE CHECKBOX)
local function CreateToggle(name, parent, yPos, defaultValue, callback)
    local isSmall = isMobile
    
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, isSmall and -20 or -30, 0, isSmall and 35 or 40)
    toggleFrame.Position = UDim2.new(0, isSmall and 10 or 15, 0, yPos)
    toggleFrame.BackgroundColor3 = COLORS.Secondary
    toggleFrame.BorderSizePixel = 0
    toggleFrame.Parent = parent
    CreateUICorner(isSmall and 6 or 8).Parent = toggleFrame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, isSmall and -40 or -50, 1, 0)
    label.Position = UDim2.new(0, isSmall and 10 or 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.Font = Enum.Font.GothamMedium
    label.TextSize = isSmall and 11 or 13
    label.TextColor3 = COLORS.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame
    
    -- CHECKBOX (KOTAK)
    local checkbox = Instance.new("TextButton")
    checkbox.Size = UDim2.new(0, isSmall and 20 or 24, 0, isSmall and 20 or 24)
