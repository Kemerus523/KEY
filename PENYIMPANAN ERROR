local isHidden = false
local savedSize = Vector2.new(GW, GH)

local function ToggleGUI()
    isHidden = not isHidden
    if isHidden then
        savedSize = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset)
        TweenObject(MainFrame, {Size = UDim2.new(0,0,0,0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3); MainFrame.Visible = false
        FloatingHideButton.Size = UDim2.new(0,0,0,0)
        FloatingHideButton.Visible = true
        TweenObject(FloatingHideButton, {Size = UDim2.new(0,45,0,45)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    else
        TweenObject(FloatingHideButton, {Size = UDim2.new(0,0,0,0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3); FloatingHideButton.Visible = false
        MainFrame.Size = UDim2.new(0,0,0,0)
        MainFrame.Visible = true
        TweenObject(MainFrame, {Size = UDim2.new(0,savedSize.X,0,savedSize.Y)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end
end

HideButton.MouseButton1Click:Connect(ToggleGUI)
FloatingHideButton.MouseButton1Click:Connect(ToggleGUI)
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.K then
        if MainFrame.Visible or FloatingHideButton.Visible then ToggleGUI() end
    end
end)

