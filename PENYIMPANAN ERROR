-- Utility
local function CreateUICorner(radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius)
    return c
end

local function CreateUIStroke(color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = thickness
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    return s
end

local function TweenObject(obj, props, dur, style, dir)
    local ti = TweenInfo.new(dur or 0.3, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out)
    local t = TweenService:Create(obj, ti, props)
    t:Play()
    return t
end

