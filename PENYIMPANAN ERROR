    CreateUICorner(4).Parent = trackBG

    local SPEED_MIN, SPEED_MAX = 16, 20
    local initRel = (currentSpeed - SPEED_MIN) / (SPEED_MAX - SPEED_MIN)

    local trackFill = Instance.new("Frame")
    trackFill.Size = UDim2.new(initRel, 0, 1, 0)
    trackFill.BackgroundColor3 = COLORS.Accent
    trackFill.BorderSizePixel = 0
    trackFill.Parent = trackBG
    CreateUICorner(4).Parent = trackFill

    local trackKnob = Instance.new("Frame")
    trackKnob.Size = UDim2.new(0, 16, 0, 16)
    trackKnob.AnchorPoint = Vector2.new(0.5, 0.5)
    trackKnob.Position = UDim2.new(initRel, 0, 0.5, 0)
    trackKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    trackKnob.BorderSizePixel = 0
    trackKnob.Parent = trackBG
    CreateUICorner(8).Parent = trackKnob
    CreateUIStroke(COLORS.Accent, 2).Parent = trackKnob

    local trackHit = Instance.new("TextButton")
    trackHit.Size = UDim2.new(1, 0, 0, 24)
    trackHit.Position = UDim2.new(0, 0, 0.5, -12)
    trackHit.BackgroundTransparency = 1
    trackHit.Text = ""; trackHit.ZIndex = 5
    trackHit.Parent = trackBG

    local sliderDragging = false
    local function UpdateSpeedSlider(absX)
        local tx = trackBG.AbsolutePosition.X
        local tw = trackBG.AbsoluteSize.X
        local rel = math.clamp((absX - tx) / tw, 0, 1)
        local rawSpeed = SPEED_MIN + rel * (SPEED_MAX - SPEED_MIN)
        currentSpeed = math.floor(rawSpeed + 0.5)
        local snapRel = (currentSpeed - SPEED_MIN) / (SPEED_MAX - SPEED_MIN)
        trackFill.Size = UDim2.new(snapRel, 0, 1, 0)
        trackKnob.Position = UDim2.new(snapRel, 0, 0.5, 0)
        speedValLbl.Text = tostring(currentSpeed)
        if speedWalkEnabled then ApplyWalkSpeed(currentSpeed) end
    end

    trackHit.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = true; UpdateSpeedSlider(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not sliderDragging then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            UpdateSpeedSlider(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then sliderDragging = false end
    end)

    -- Status hint
    local statusLbl = Instance.new("TextLabel")
    statusLbl.Size = UDim2.new(1, -24, 0, 20)
    statusLbl.Position = UDim2.new(0, 12, 0, 84)
    statusLbl.BackgroundTransparency = 1
    statusLbl.Text = speedWalkEnabled and ("Aktif  •  Speed: " .. currentSpeed) or "Nonaktif  •  Default: 16  •  Maks: 20"
    statusLbl.Font = Enum.Font.Gotham; statusLbl.TextSize = 9
    statusLbl.TextColor3 = speedWalkEnabled and COLORS.Success or COLORS.TextDim
    statusLbl.TextXAlignment = Enum.TextXAlignment.Left
    statusLbl.Parent = speedCard

    -- Toggle logic
    pillBtn.MouseButton1Click:Connect(function()
        speedWalkEnabled = not speedWalkEnabled
        TweenObject(togglePill, {BackgroundColor3 = speedWalkEnabled and COLORS.Accent or COLORS.Border}, 0.2)
        TweenObject(pillCircle, {Position = speedWalkEnabled and UDim2.new(1,-20,0.5,-9) or UDim2.new(0,2,0.5,-9)}, 0.2)

        if speedWalkEnabled then
            StartSpeedLoop()
            ApplyWalkSpeed(currentSpeed)
            statusLbl.Text = "Aktif  •  Speed: " .. currentSpeed
            statusLbl.TextColor3 = COLORS.Success
        else
            StopSpeedLoop()  -- otomatis reset ke 16
            currentSpeed = 16
            -- Update slider visual ke 16
            local snapRel = 0
            trackFill.Size = UDim2.new(snapRel, 0, 1, 0)
            trackKnob.Position = UDim2.new(snapRel, 0, 0.5, 0)
            speedValLbl.Text = "16"
            statusLbl.Text = "Nonaktif  •  Default: 16  •  Maks: 20"
            statusLbl.TextColor3 = COLORS.TextDim
        end
    end)

    scroll.CanvasSize = UDim2.new(0, 0, 0, 180)
end

