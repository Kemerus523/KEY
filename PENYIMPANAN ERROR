local function CreateColorPicker(name, parent, yPos, defaultColor, callback)
    local isSmall = isMobile

    local pickerFrame = Instance.new("Frame")
    pickerFrame.Size = UDim2.new(1, isSmall and -20 or -30, 0, isSmall and 35 or 40)
    pickerFrame.Position = UDim2.new(0, isSmall and 10 or 15, 0, yPos)
    pickerFrame.BackgroundColor3 = COLORS.Secondary
    pickerFrame.BorderSizePixel = 0
    pickerFrame.Parent = parent
    CreateUICorner(isSmall and 6 or 8).Parent = pickerFrame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, isSmall and -60 or -70, 1, 0)
    label.Position = UDim2.new(0, isSmall and 10 or 12, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.Font = Enum.Font.GothamMedium
    label.TextSize = isSmall and 11 or 13
    label.TextColor3 = COLORS.Text
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = pickerFrame

    local colorDisplay = Instance.new("TextButton")
    colorDisplay.Size = UDim2.new(0, isSmall and 45 or 50, 0, isSmall and 22 or 25)
    colorDisplay.Position = UDim2.new(1, isSmall and -50 or -55, 0.5, isSmall and -11 or -12)
    colorDisplay.BackgroundColor3 = defaultColor
    colorDisplay.BorderSizePixel = 0
    colorDisplay.Text = ""
    colorDisplay.AutoButtonColor = false
    colorDisplay.Parent = pickerFrame
    CreateUICorner(isSmall and 4 or 6).Parent = colorDisplay
    CreateUIStroke(COLORS.Border, 1).Parent = colorDisplay

    -- Picker Window — lebih besar & akurat
    local WHEEL_SIZE = 180
    local WHEEL_RADIUS = WHEEL_SIZE / 2

    local pickerWindow = Instance.new("Frame")
    pickerWindow.Size = UDim2.new(0, WHEEL_SIZE + 40, 0, WHEEL_SIZE + 100)
    pickerWindow.Position = UDim2.new(0.5, -(WHEEL_SIZE/2 + 20), 0.5, -(WHEEL_SIZE/2 + 50))
    pickerWindow.BackgroundColor3 = COLORS.Background
    pickerWindow.BorderSizePixel = 0
    pickerWindow.Visible = false
    pickerWindow.ZIndex = 200
    pickerWindow.Parent = ScreenGui
    CreateUICorner(12).Parent = pickerWindow
    CreateUIStroke(COLORS.Border, 2).Parent = pickerWindow

    local pickerTitle = Instance.new("TextLabel")
    pickerTitle.Size = UDim2.new(1, 0, 0, 30)
    pickerTitle.BackgroundTransparency = 1
    pickerTitle.Text = "Pick Color — " .. name
    pickerTitle.Font = Enum.Font.GothamBold
    pickerTitle.TextSize = 13
    pickerTitle.TextColor3 = COLORS.Text
    pickerTitle.Parent = pickerWindow

    -- Color Wheel (ImageButton pakai rbxassetid colorwheel standard)
    local colorWheel = Instance.new("ImageButton")
    colorWheel.Size = UDim2.new(0, WHEEL_SIZE, 0, WHEEL_SIZE)
    colorWheel.Position = UDim2.new(0.5, -WHEEL_RADIUS, 0, 35)
    colorWheel.BackgroundTransparency = 1
    colorWheel.Image = "rbxassetid://698052001"
    colorWheel.ZIndex = 201
    colorWheel.Parent = pickerWindow
    CreateUICorner(WHEEL_RADIUS).Parent = colorWheel

    -- Value (brightness) slider di bawah wheel
    local valueSliderBG = Instance.new("Frame")
    valueSliderBG.Size = UDim2.new(0, WHEEL_SIZE, 0, 14)
    valueSliderBG.Position = UDim2.new(0.5, -WHEEL_RADIUS, 0, 35 + WHEEL_SIZE + 8)
    valueSliderBG.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    valueSliderBG.BorderSizePixel = 0
    valueSliderBG.ZIndex = 201
    valueSliderBG.Parent = pickerWindow
    CreateUICorner(7).Parent = valueSliderBG

    -- Gradient hitam→putih (representasi brightness)
    local valGrad = Instance.new("UIGradient")
    valGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))
    }
    valGrad.Rotation = 90
    valGrad.Parent = valueSliderBG

    local valueKnob = Instance.new("Frame")
    valueKnob.Size = UDim2.new(0, 14, 0, 14)
    valueKnob.AnchorPoint = Vector2.new(0.5, 0.5)
    valueKnob.Position = UDim2.new(1, 0, 0.5, 0)  -- default brightness = 1
    valueKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    valueKnob.BorderSizePixel = 0
    valueKnob.ZIndex = 202
    valueKnob.Parent = valueSliderBG
    CreateUICorner(7).Parent = valueKnob
    CreateUIStroke(Color3.fromRGB(0,0,0), 2).Parent = valueKnob

    -- Cursor di atas wheel
    local cursor = Instance.new("Frame")
    cursor.Size = UDim2.new(0, 10, 0, 10)
    cursor.AnchorPoint = Vector2.new(0.5, 0.5)
    cursor.Position = UDim2.new(0.5, 0, 0.5, 0)
    cursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    cursor.BorderSizePixel = 0
    cursor.ZIndex = 202
    cursor.Parent = colorWheel
    CreateUICorner(5).Parent = cursor
    CreateUIStroke(Color3.fromRGB(0,0,0), 2).Parent = cursor

    -- Preview box
    local previewBox = Instance.new("Frame")
    previewBox.Size = UDim2.new(0, WHEEL_SIZE, 0, 22)
    previewBox.Position = UDim2.new(0.5, -WHEEL_RADIUS, 0, 35 + WHEEL_SIZE + 8 + 18)
    previewBox.BackgroundColor3 = defaultColor
    previewBox.BorderSizePixel = 0
    previewBox.ZIndex = 201
    previewBox.Parent = pickerWindow
    CreateUICorner(6).Parent = previewBox
    CreateUIStroke(COLORS.Border, 1).Parent = previewBox

    -- Hex label
    local hexLabel = Instance.new("TextLabel")
    hexLabel.Size = UDim2.new(1, 0, 1, 0)
    hexLabel.BackgroundTransparency = 1
    hexLabel.Text = "#FFFFFF"
    hexLabel.Font = Enum.Font.GothamBold
    hexLabel.TextSize = 11
    hexLabel.TextColor3 = Color3.fromRGB(255,255,255)
    hexLabel.ZIndex = 202
    hexLabel.Parent = previewBox

    local closeButton = Instance.new("TextButton")
    closeButton.Size = UDim2.new(1, -20, 0, 28)
    closeButton.Position = UDim2.new(0, 10, 1, -38)
    closeButton.BackgroundColor3 = COLORS.Accent
    closeButton.BorderSizePixel = 0
    closeButton.Text = "Apply & Close"
    closeButton.Font = Enum.Font.GothamBold
    closeButton.TextSize = 12
    closeButton.TextColor3 = Color3.fromRGB(255,255,255)
    closeButton.AutoButtonColor = false
    closeButton.ZIndex = 202
    closeButton.Parent = pickerWindow
    CreateUICorner(7).Parent = closeButton

    closeButton.MouseButton1Click:Connect(function()
        pickerWindow.Visible = false
    end)

    -- State
    local currentHue = 0
    local currentSat = 0
    local currentVal = 1

    -- Init dari defaultColor
    local r, g, b = defaultColor.R, defaultColor.G, defaultColor.B
    local maxC = math.max(r, g, b)
    local minC = math.min(r, g, b)
    local delta = maxC - minC
    currentVal = maxC
    currentSat = maxC == 0 and 0 or (delta / maxC)
    if delta == 0 then
        currentHue = 0
    elseif maxC == r then
        currentHue = ((g - b) / delta) % 6 / 6
    elseif maxC == g then
        currentHue = ((b - r) / delta + 2) / 6
    else
        currentHue = ((r - g) / delta + 4) / 6
    end

    local function RGBToHex(color)
        return string.format("#%02X%02X%02X",
            math.floor(color.R * 255),
            math.floor(color.G * 255),
            math.floor(color.B * 255))
    end

    local function HSVToColor3(h, s, v)
        local c = v * s
        local x = c * (1 - math.abs((h * 6) % 2 - 1))
        local m = v - c
        local r2, g2, b2 = 0, 0, 0
        if     h < 1/6 then r2, g2, b2 = c, x, 0
        elseif h < 2/6 then r2, g2, b2 = x, c, 0
        elseif h < 3/6 then r2, g2, b2 = 0, c, x
        elseif h < 4/6 then r2, g2, b2 = 0, x, c
        elseif h < 5/6 then r2, g2, b2 = x, 0, c
        else                r2, g2, b2 = c, 0, x
        end
        return Color3.new(r2 + m, g2 + m, b2 + m)
    end

    local function ApplyColor()
        local newColor = HSVToColor3(currentHue, currentSat, currentVal)
        colorDisplay.BackgroundColor3 = newColor
        previewBox.BackgroundColor3 = newColor
        hexLabel.Text = RGBToHex(newColor)
        -- Warna teks hex sesuai kecerahan
        hexLabel.TextColor3 = currentVal > 0.5 and Color3.fromRGB(0,0,0) or Color3.fromRGB(255,255,255)
        if callback then callback(newColor) end
    end

    -- Update cursor posisi dari hue+sat
    local function UpdateCursorFromHS()
        local angle = currentHue * 2 * math.pi
        local dist = currentSat * WHEEL_RADIUS
        local cx = WHEEL_RADIUS + math.cos(angle) * dist
        local cy = WHEEL_RADIUS + math.sin(angle) * dist
        cursor.Position = UDim2.new(0, cx - 5, 0, cy - 5)
    end

    -- Update value knob posisi dari currentVal
    local function UpdateValueKnob()
        valueKnob.Position = UDim2.new(currentVal, 0, 0.5, 0)
    end

    UpdateCursorFromHS()
    UpdateValueKnob()
    ApplyColor()

    -- Wheel drag
    local wheelDragging = false

    local function HandleWheelInput(absX, absY)
        local wx = colorWheel.AbsolutePosition.X
        local wy = colorWheel.AbsolutePosition.Y
        local rx = absX - wx - WHEEL_RADIUS
        local ry = absY - wy - WHEEL_RADIUS
        local dist = math.sqrt(rx*rx + ry*ry)

        -- Clamp ke dalam lingkaran
        if dist > WHEEL_RADIUS then
            local angle = math.atan2(ry, rx)
            rx = math.cos(angle) * WHEEL_RADIUS
            ry = math.sin(angle) * WHEEL_RADIUS
            dist = WHEEL_RADIUS
        end

        currentHue = (math.atan2(ry, rx) / (2 * math.pi)) % 1
        currentSat = dist / WHEEL_RADIUS

        -- Update cursor visual
        cursor.Position = UDim2.new(0, rx + WHEEL_RADIUS - 5, 0, ry + WHEEL_RADIUS - 5)
        ApplyColor()
    end

    colorWheel.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            wheelDragging = true
            HandleWheelInput(input.Position.X, input.Position.Y)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not wheelDragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            HandleWheelInput(input.Position.X, input.Position.Y)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            wheelDragging = false
        end
    end)

    -- Value slider drag
    local valDragging = false

    local function HandleValInput(absX)
        local slx = valueSliderBG.AbsolutePosition.X
        local slw = valueSliderBG.AbsoluteSize.X
        currentVal = math.clamp((absX - slx) / slw, 0, 1)
        valueKnob.Position = UDim2.new(currentVal, 0, 0.5, 0)
        ApplyColor()
    end

    valueSliderBG.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            valDragging = true
            HandleValInput(input.Position.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not valDragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            HandleValInput(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            valDragging = false
        end
    end)

    colorDisplay.MouseButton1Click:Connect(function()
        pickerWindow.Visible = not pickerWindow.Visible
    end)

    return colorDisplay
end

