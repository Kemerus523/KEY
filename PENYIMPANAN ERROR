-- PLAYERS TAB — Speed Walk
-- =============================================
local speedWalkEnabled = false
local currentSpeed = 16
local walkSpeedConn = nil

local function ApplyWalkSpeed(speed)
    local ch = LocalPlayer.Character
    if not ch then return end
    local hum = ch:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed = speed end
end

local function StartSpeedLoop()
    if walkSpeedConn then walkSpeedConn:Disconnect() end
    -- Re-apply setiap karakter respawn
    walkSpeedConn = RunService.Heartbeat:Connect(function()
        if not speedWalkEnabled then return end
        local ch = LocalPlayer.Character
        if not ch then return end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if hum and hum.WalkSpeed ~= currentSpeed then
            hum.WalkSpeed = currentSpeed
        end
    end)
end

local function StopSpeedLoop()
    if walkSpeedConn then walkSpeedConn:Disconnect(); walkSpeedConn = nil end
    -- Reset ke default
    local ch = LocalPlayer.Character
    if not ch then return end
    local hum = ch:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed = 16 end
end

-- Respawn safety
LocalPlayer.CharacterAdded:Connect(function(char)
    if speedWalkEnabled then
        task.wait(0.5)
        local hum = char:WaitForChild("Humanoid", 5)
        if hum then hum.WalkSpeed = currentSpeed end
    end
end)

