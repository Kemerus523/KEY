local TabData = {
    {Name = "Combat",  Icon = "⚔"},
    {Name = "Players", Icon = "👤"},
    {Name = "Visuals", Icon = "👀"},
    {Name = "Misc",    Icon = "⚙"},
    {Name = "Credits", Icon = "⭐"}
}

local SelectedTab = nil
local TabButtons = {}

local function SelectTab(tabName)
    if SelectedTab == tabName then return end
    if SelectedTab and TabButtons[SelectedTab] then
        local prev = TabButtons[SelectedTab]
        TweenObject(prev.Button, {BackgroundColor3 = COLORS.Secondary}, 0.2)
        TweenObject(prev.Icon,   {TextColor3 = COLORS.TextDim}, 0.2)
        TweenObject(prev.Label,  {TextColor3 = COLORS.TextDim}, 0.2)
        TweenObject(prev.Indicator, {Size = UDim2.new(0, 2.5, 0, 0)}, 0.3)
    end

    SelectedTab = tabName
    local cur = TabButtons[tabName]
    TweenObject(cur.Button, {BackgroundColor3 = Color3.fromRGB(35,35,45)}, 0.2)
    TweenObject(cur.Icon,   {TextColor3 = COLORS.Accent}, 0.2)
    TweenObject(cur.Label,  {TextColor3 = COLORS.Text}, 0.2)
    TweenObject(cur.Indicator, {Size = UDim2.new(0, 2.5, 1, -8)}, 0.3, Enum.EasingStyle.Back)

    if tabName == "Combat" then
        CreateCombatContent()
    elseif tabName == "Players" then
        CreatePlayersContent()
    elseif tabName == "Visuals" then
        CreateVisualsContent()
    elseif tabName == "Credits" then
        CreateCreditsContent()
    else
        for _, c in pairs(ContentFrame:GetChildren()) do c:Destroy() end
        local ph = Instance.new("TextLabel")
        ph.Size = UDim2.new(1, 0, 1, 0)
        ph.BackgroundTransparency = 1
        ph.Text = tabName .. " — Coming soon"
        ph.Font = Enum.Font.Gotham; ph.TextSize = 13
        ph.TextColor3 = COLORS.TextDim
        ph.Parent = ContentFrame
    end
end

for i, tabData in ipairs(TabData) do
