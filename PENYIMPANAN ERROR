    trackFill.BackgroundColor3 = COLORS.Accent
    trackFill.BorderSizePixel = 0
    trackFill.Parent = trackBG
    CreateUICorner(3).Parent = trackFill

    local trackKnob = Instance.new("Frame")
    trackKnob.Size = UDim2.new(0, 14, 0, 14)
    trackKnob.AnchorPoint = Vector2.new(0.5, 0.5)
    trackKnob.Position = UDim2.new(initRel, 0, 0.5, 0)
    trackKnob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    trackKnob.BorderSizePixel = 0
    trackKnob.Parent = trackBG
    CreateUICorner(7).Parent = trackKnob
    local knobStroke = CreateUIStroke(COLORS.Accent, 2); knobStroke.Parent = trackKnob

    -- Invisible hit area
    local trackHit = Instance.new("TextButton")
    trackHit.Size = UDim2.new(1, 0, 0, 22)
    trackHit.Position = UDim2.new(0, 0, 0.5, -11)
    trackHit.BackgroundTransparency = 1
    trackHit.Text = ""
    trackHit.ZIndex = 5
    trackHit.Parent = trackBG

    local sliderDragging = false
    local function UpdateSpeedSlider(absX)
        local tx = trackBG.AbsolutePosition.X
        local tw = trackBG.AbsoluteSize.X
        local rel = math.clamp((absX - tx) / tw, 0, 1)
        -- Snap ke integer (16,17,18,19,20)
        local rawSpeed = SPEED_MIN + rel * (SPEED_MAX - SPEED_MIN)
        currentSpeed = math.floor(rawSpeed + 0.5)
        local snapRel = (currentSpeed - SPEED_MIN) / (SPEED_MAX - SPEED_MIN)
        trackFill.Size = UDim2.new(snapRel, 0, 1, 0)
        trackKnob.Position = UDim2.new(snapRel, 0, 0.5, 0)
        speedValLbl.Text = tostring(currentSpeed)
        if speedWalkEnabled then ApplyWalkSpeed(currentSpeed) end
    end

    trackHit.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = true
            UpdateSpeedSlider(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not sliderDragging then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then
            UpdateSpeedSlider(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = false
        end
    end)

    -- Info hint
    local hintLbl = Instance.new("TextLabel")
    hintLbl.Size = UDim2.new(1, -24, 0, 16)
    hintLbl.Position = UDim2.new(0, 12, 0, 88)
    hintLbl.BackgroundTransparency = 1
    hintLbl.Text = "Default: 16  •  Max: 20"
    hintLbl.Font = Enum.Font.Gotham
    hintLbl.TextSize = 9
    hintLbl.TextColor3 = COLORS.TextDim
    hintLbl.TextXAlignment = Enum.TextXAlignment.Left
    hintLbl.Parent = speedCard

    scroll.CanvasSize = UDim2.new(0, 0, 0, 160)
end

local function SelectTab(tabName)
    if SelectedTab == tabName then return end

    if SelectedTab and TabButtons[SelectedTab] then
        local prev = TabButtons[SelectedTab]
        TweenObject(prev.Button, {BackgroundColor3 = COLORS.Secondary}, 0.2)
        TweenObject(prev.Icon,   {TextColor3 = COLORS.TextDim}, 0.2)
        TweenObject(prev.Label,  {TextColor3 = COLORS.TextDim}, 0.2)
        TweenObject(prev.Indicator, {Size = UDim2.new(0, 2.5, 0, 0)}, 0.3)
    end

    SelectedTab = tabName
    local cur = TabButtons[tabName]
    TweenObject(cur.Button, {BackgroundColor3 = Color3.fromRGB(35,35,45)}, 0.2)
    TweenObject(cur.Icon,   {TextColor3 = COLORS.Accent}, 0.2)
    TweenObject(cur.Label,  {TextColor3 = COLORS.Text}, 0.2)
    TweenObject(cur.Indicator, {Size = UDim2.new(0, 2.5, 1, -8)}, 0.3, Enum.EasingStyle.Back)

    -- Load content
    if tabName == "Visuals" then
        CreateVisualsContent()
    elseif tabName == "Players" then
        CreatePlayersContent()
    elseif tabName == "Credits" then
        CreateCreditsContent()
    else
        for _, c in pairs(ContentFrame:GetChildren()) do c:Destroy() end
        local ph = Instance.new("TextLabel")
        ph.Size = UDim2.new(1, 0, 1, 0)
        ph.BackgroundTransparency = 1
        ph.Text = tabName .. " — Coming soon"
        ph.Font = Enum.Font.Gotham
        ph.TextSize = 13
        ph.TextColor3 = COLORS.TextDim
        ph.Parent = ContentFrame
    end
end

