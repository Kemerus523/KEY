-- DRAGGING SYSTEM
local dragging = false
local dragInput, dragStart, startPos

local function updateDrag(input)
    if not dragging then return end
    
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        updateDrag(input)
    end
end)

-- HIDE/SHOW SYSTEM
local isHidden = false
local savedSize = Vector2.new(CONFIG.DefaultSize.X, CONFIG.DefaultSize.Y)

local function ToggleGUI()
    isHidden = not isHidden
    
    if isHidden then
        savedSize = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset)
        
        TweenObject(MainFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3)
        MainFrame.Visible = false
        
        FloatingHideButton.Size = UDim2.new(0, 0, 0, 0)
        FloatingHideButton.Visible = true
        TweenObject(FloatingHideButton, {Size = UDim2.new(0, isMobile and 45 or 50, 0, isMobile and 45 or 50)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    else
        TweenObject(FloatingHideButton, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3)
        FloatingHideButton.Visible = false
        
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        MainFrame.Visible = true
        TweenObject(MainFrame, {Size = UDim2.new(0, savedSize.X, 0, savedSize.Y)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end
end

HideButton.MouseButton1Click:Connect(ToggleGUI)
FloatingHideButton.MouseButton1Click:Connect(ToggleGUI)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.K then
        if MainFrame.Visible or FloatingHideButton.Visible then
            ToggleGUI()
        end
    end
end)

-- FLOATING BUTTON DRAG SYSTEM
local floatingDragging = false
local floatingDragStart, floatingStartPos

FloatingHideButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        floatingDragging = true
        floatingDragStart = input.Position
        floatingStartPos = FloatingHideButton.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                floatingDragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not floatingDragging then return end
    
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - floatingDragStart
        FloatingHideButton.Position = UDim2.new(
            floatingStartPos.X.Scale,
            floatingStartPos.X.Offset + delta.X,
            floatingStartPos.Y.Scale,
            floatingStartPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.TouchEnded:Connect(function(input, gameProcessed)
    if floatingDragging then
        floatingDragging = false
    end
end)

FloatingHideButton.MouseEnter:Connect(function()
    TweenObject(FloatingHideButton, {Size = UDim2.new(0, isMobile and 50 or 55, 0, isMobile and 50 or 55)}, 0.2)
    TweenObject(FloatingHideButton, {BackgroundColor3 = Color3.fromRGB(55, 150, 255)}, 0.2)
end)

FloatingHideButton.MouseLeave:Connect(function()
    if not floatingDragging then
        TweenObject(FloatingHideButton, {Size = UDim2.new(0, isMobile and 45 or 50, 0, isMobile and 45 or 50)}, 0.2)
        TweenObject(FloatingHideButton, {BackgroundColor3 = COLORS.Accent}, 0.2)
    end
end)

