        pickerWindow.Visible = false
    end)
    
    -- Color Logic
    local currentHue = 0
    local currentSat = 1
    local currentVal = 1
    
    local function UpdateColor()
        local color = HSVToRGB(currentHue, currentSat, currentVal)
        colorDisplay.BackgroundColor3 = color
        colorPreview.BackgroundColor3 = color
        
        local r = math.floor(color.R * 255)
        local g = math.floor(color.G * 255)
        local b = math.floor(color.B * 255)
        rgbDisplay.Text = string.format("RGB: %d, %d, %d", r, g, b)
        
        if callback then
            callback(color)
        end
    end
    
    local function UpdateCanvasColor()
        local hueColor = HSVToRGB(currentHue, 1, 1)
        colorCanvas.ImageColor3 = hueColor
    end
    
    -- Canvas Click
    local canvasDragging = false
    colorCanvas.MouseButton1Down:Connect(function()
        canvasDragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            canvasDragging = false
        end
    end)
    
    colorCanvas.MouseMoved:Connect(function(x, y)
        if canvasDragging then
            local relativeX = math.clamp(x - colorCanvas.AbsolutePosition.X, 0, colorCanvas.AbsoluteSize.X)
            local relativeY = math.clamp(y - colorCanvas.AbsolutePosition.Y, 0, colorCanvas.AbsoluteSize.Y)
            
            currentSat = relativeX / colorCanvas.AbsoluteSize.X
            currentVal = 1 - (relativeY / colorCanvas.AbsoluteSize.Y)
            
            cursor.Position = UDim2.new(0, relativeX, 0, relativeY)
            UpdateColor()
        end
    end)
    
    colorCanvas.MouseButton1Click:Connect(function(x, y)
        local relativeX = math.clamp(x - colorCanvas.AbsolutePosition.X, 0, colorCanvas.AbsoluteSize.X)
        local relativeY = math.clamp(y - colorCanvas.AbsolutePosition.Y, 0, colorCanvas.AbsoluteSize.Y)
        
        currentSat = relativeX / colorCanvas.AbsoluteSize.X
        currentVal = 1 - (relativeY / colorCanvas.AbsoluteSize.Y)
        
        cursor.Position = UDim2.new(0, relativeX, 0, relativeY)
        UpdateColor()
    end)
    
    -- Hue Slider Click
    local hueDragging = false
    hueSlider.MouseButton1Down:Connect(function()
        hueDragging = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)
    
    hueSlider.MouseMoved:Connect(function(x, y)
        if hueDragging then
            local relativeX = math.clamp(x - hueSlider.AbsolutePosition.X, 0, hueSlider.AbsoluteSize.X)
            currentHue = relativeX / hueSlider.AbsoluteSize.X
            
            hueCursor.Position = UDim2.new(0, relativeX - 2, 0, -2)
            UpdateCanvasColor()
            UpdateColor()
        end
    end)
    
    hueSlider.MouseButton1Click:Connect(function(x, y)
        local relativeX = math.clamp(x - hueSlider.AbsolutePosition.X, 0, hueSlider.AbsoluteSize.X)
        currentHue = relativeX / hueSlider.AbsoluteSize.X
        
        hueCursor.Position = UDim2.new(0, relativeX - 2, 0, -2)
        UpdateCanvasColor()
        UpdateColor()
    end)
    
    colorDisplay.MouseButton1Click:Connect(function()
        pickerWindow.Visible = not pickerWindow.Visible
    end)
    
    return colorDisplay
end

