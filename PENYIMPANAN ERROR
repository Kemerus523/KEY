-- Key System Logic
local function ValidateKey(key)
    return key == CONFIG.ValidKey
end

local function ShowNotification(message, isSuccess)
    InfoText.Text = message
    InfoText.TextColor3 = isSuccess and COLORS.Success or COLORS.Error
    
    task.wait(2)
    if not isSuccess then
        InfoText.Text = "Enter your key to continue"
        InfoText.TextColor3 = COLORS.TextDim
    end
end

SubmitButton.MouseButton1Click:Connect(function()
    local key = KeyInputBox.Text
    
    if key == "" then
        ShowNotification("Please enter a key!", false)
        return
    end
    
    if ValidateKey(key) then
