    -- ===== STATE =====
    local curH, curS, curV = 0, 0, 1
    do
        local r,g,b = defaultColor.R, defaultColor.G, defaultColor.B
        local mx = math.max(r,g,b); local mn = math.min(r,g,b); local d = mx - mn
        curV = mx
        curS = mx == 0 and 0 or (d/mx)
        if d == 0 then curH = 0
        elseif mx == r then curH = ((g-b)/d) % 6 / 6
        elseif mx == g then curH = ((b-r)/d + 2) / 6
        else curH = ((r-g)/d + 4) / 6 end
    end

    local function HSVtoC3(h,s,v)
        local c=v*s; local x=c*(1-math.abs((h*6)%2-1)); local m=v-c
        local r,g,b=0,0,0
        if h<1/6 then r,g,b=c,x,0 elseif h<2/6 then r,g,b=x,c,0
        elseif h<3/6 then r,g,b=0,c,x elseif h<4/6 then r,g,b=0,x,c
        elseif h<5/6 then r,g,b=x,0,c else r,g,b=c,0,x end
        return Color3.new(r+m,g+m,b+m)
    end

    local function ToHex(c)
        return string.format("%02X%02X%02X",
            math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
    end

    local function ApplyAll()
