local function GetPlayerInventory(player)
    local inventory = {}
    if player:FindFirstChild("Backpack") then
        for _, item in pairs(player.Backpack:GetChildren()) do
            if item:IsA("Tool") then table.insert(inventory, item.Name) end
        end
    end
    if player.Character then
        for _, item in pairs(player.Character:GetChildren()) do
            if item:IsA("Tool") then table.insert(inventory, item.Name .. " [E]") end
        end
    end
    return inventory
end

local function CreateESP(player)
    if player == LocalPlayer then return end

    local esp = { Player = player, Drawings = {} }

    -- Box
    local box = Drawing.new("Square")
    box.Visible = false; box.Color = ESPSettings.BoxColor
    box.Thickness = 1.5; box.Transparency = 1; box.Filled = false
    esp.Drawings.Box = box

    -- Tracer
    local tracer = Drawing.new("Line")
    tracer.Visible = false; tracer.Color = ESPSettings.TracerColor
    tracer.Thickness = 1.5; tracer.Transparency = 1
    esp.Drawings.Tracer = tracer

    -- Health Bar BG
    local healthBarBG = Drawing.new("Square")
    healthBarBG.Visible = false; healthBarBG.Color = Color3.fromRGB(0,0,0)
    healthBarBG.Thickness = 1; healthBarBG.Transparency = 0.5; healthBarBG.Filled = true
    esp.Drawings.HealthBarBG = healthBarBG

    -- Health Bar
    local healthBar = Drawing.new("Square")
    healthBar.Visible = false; healthBar.Color = ESPSettings.HealthBarColor
    healthBar.Thickness = 1; healthBar.Transparency = 1; healthBar.Filled = true
    esp.Drawings.HealthBar = healthBar

    -- Name Text  (BARU)
    local nameText = Drawing.new("Text")
    nameText.Visible = false
    nameText.Color = ESPSettings.NameColor
    nameText.Size = 14
    nameText.Center = true
    nameText.Outline = true
    nameText.OutlineColor = Color3.fromRGB(0,0,0)
    nameText.Font = 2
    nameText.Text = player.DisplayName .. " (@" .. player.Name .. ")"
    esp.Drawings.NameText = nameText

    -- Distance Text
    local distanceText = Drawing.new("Text")
    distanceText.Visible = false; distanceText.Color = Color3.fromRGB(255,255,255)
    distanceText.Size = 13; distanceText.Center = true
    distanceText.Outline = true; distanceText.OutlineColor = Color3.fromRGB(0,0,0)
    distanceText.Font = 2
    esp.Drawings.DistanceText = distanceText

    -- Inventory Text (max 5 baris vertikal)
    esp.Drawings.InventoryLines = {}
    for i = 1, 5 do
        local invLine = Drawing.new("Text")
        invLine.Visible = false
        invLine.Color = Color3.fromRGB(200, 200, 200)
        invLine.Size = 12
        invLine.Center = true
        invLine.Outline = true
        invLine.OutlineColor = Color3.fromRGB(0, 0, 0)
        invLine.Font = 2
        invLine.Text = ""
        table.insert(esp.Drawings.InventoryLines, invLine)
    end

    ESPObjects[player] = esp
end

local function RemoveESP(player)
    local esp = ESPObjects[player]
    if esp then
        for _, drawing in pairs(esp.Drawings) do
            if type(drawing) == "userdata" then
                pcall(function() drawing:Remove() end)
            end
        end
        if esp.Drawings.InventoryLines then
            for _, line in ipairs(esp.Drawings.InventoryLines) do
                pcall(function() line:Remove() end)
            end
        end
        ESPObjects[player] = nil
    end
end

local function UpdateESP()
    if not ESPSettings.Enabled then
        for _, esp in pairs(ESPObjects) do
            for _, drawing in pairs(esp.Drawings) do
                if type(drawing) == "userdata" then drawing.Visible = false end
            end
            if esp.Drawings.InventoryLines then
                for _, line in ipairs(esp.Drawings.InventoryLines) do line.Visible = false end
            end
        end
        return
    end

    local localChar = LocalPlayer.Character
    local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")

    for player, esp in pairs(ESPObjects) do
        local ch = player.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum = ch and ch:FindFirstChild("Humanoid")
        local head = ch and ch:FindFirstChild("Head")

        if ch and hrp and hum and head then
            local vec, onScreen = Camera:WorldToViewportPoint(hrp.Position)

            if onScreen then
                local headVec = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.6, 0))
                local feetVec = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 2.8, 0))

                local height = math.abs(headVec.Y - feetVec.Y)
                local width = height * 0.5
                local topY = math.min(headVec.Y, feetVec.Y)

                -- Box
                if ESPSettings.Box then
                    esp.Drawings.Box.Size = Vector2.new(width, height)
                    esp.Drawings.Box.Position = Vector2.new(vec.X - width/2, topY)
                    esp.Drawings.Box.Color = ESPSettings.BoxColor
                    esp.Drawings.Box.Visible = true
                else
                    esp.Drawings.Box.Visible = false
                end

                -- Name (di atas box)
                if ESPSettings.Name then
                    esp.Drawings.NameText.Text = player.DisplayName .. " (@" .. player.Name .. ")"
                    esp.Drawings.NameText.Position = Vector2.new(vec.X, topY - 18)
                    esp.Drawings.NameText.Color = ESPSettings.NameColor
                    esp.Drawings.NameText.Visible = true
                else
                    esp.Drawings.NameText.Visible = false
                end

                -- Tracer
                if ESPSettings.Tracer then
                    esp.Drawings.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    esp.Drawings.Tracer.To = Vector2.new(vec.X, vec.Y + height/2)
                    esp.Drawings.Tracer.Color = ESPSettings.TracerColor
                    esp.Drawings.Tracer.Visible = true
                else
                    esp.Drawings.Tracer.Visible = false
                end

                -- Health Bar
                if ESPSettings.HealthBar then
                    local hp = hum.Health / math.max(hum.MaxHealth, 1)
                    local barW = 4

                    esp.Drawings.HealthBarBG.Size = Vector2.new(barW, height)
                    esp.Drawings.HealthBarBG.Position = Vector2.new(vec.X - width/2 - barW - 3, topY)
                    esp.Drawings.HealthBarBG.Visible = true

                    esp.Drawings.HealthBar.Size = Vector2.new(barW, height * hp)
                    esp.Drawings.HealthBar.Position = Vector2.new(vec.X - width/2 - barW - 3, topY + height * (1 - hp))
                    esp.Drawings.HealthBar.Color = ESPSettings.HealthBarColor
                    esp.Drawings.HealthBar.Visible = true
                else
                    esp.Drawings.HealthBarBG.Visible = false
                    esp.Drawings.HealthBar.Visible = false
                end

                -- Distance
                if ESPSettings.Distance and localHRP then
                    local dist = math.floor((localHRP.Position - hrp.Position).Magnitude)
                    esp.Drawings.DistanceText.Text = dist .. "m"
                    esp.Drawings.DistanceText.Position = Vector2.new(vec.X, topY + height + 4)
                    esp.Drawings.DistanceText.Visible = true
                else
                    esp.Drawings.DistanceText.Visible = false
                end

                -- Inventory (vertikal ke bawah, tiap item baris baru)
                if ESPSettings.Inventory then
                    local inv = GetPlayerInventory(player)
                    local baseY = topY + height + (ESPSettings.Distance and 18 or 4)
                    for i, line in ipairs(esp.Drawings.InventoryLines) do
                        if inv[i] then
                            line.Text = inv[i]
                            line.Position = Vector2.new(vec.X, baseY + (i - 1) * 14)
                            line.Visible = true
                        else
                            line.Visible = false
                        end
                    end
                else
                    for _, line in ipairs(esp.Drawings.InventoryLines) do
                        line.Visible = false
                    end
                end
            else
                for _, d in pairs(esp.Drawings) do
                    if type(d) == "userdata" then d.Visible = false end
                end
                if esp.Drawings.InventoryLines then
                    for _, line in ipairs(esp.Drawings.InventoryLines) do line.Visible = false end
                end
            end
        else
            for _, d in pairs(esp.Drawings) do
                if type(d) == "userdata" then d.Visible = false end
            end
            if esp.Drawings.InventoryLines then
                for _, line in ipairs(esp.Drawings.InventoryLines) do line.Visible = false end
            end
        end
    end
end

for _, player in pairs(Players:GetPlayers()) do CreateESP(player) end
Players.PlayerAdded:Connect(CreateESP)
Players.PlayerRemoving:Connect(RemoveESP)
