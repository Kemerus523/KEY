-- ================================================
-- DELETE OBJECT SYSTEM
-- ================================================
local deleteStack  = {}
local MAX_UNDO     = 50
local deleteConn   = nil
local undoCountLbl = nil

local function savePartData(part)
	return {
		part   = part,
		parent = part.Parent,
		cframe = part:IsA("BasePart") and part.CFrame or nil,
		properties = {
			Anchored     = part:IsA("BasePart") and part.Anchored     or nil,
			CanCollide   = part:IsA("BasePart") and part.CanCollide   or nil,
			Transparency = part:IsA("BasePart") and part.Transparency or nil,
		},
	}
end

local function updateUndoLabel()
	if undoCountLbl then
		local n = #deleteStack
		undoCountLbl.Text = "Tersimpan: " .. n .. "/" .. MAX_UNDO
		undoCountLbl.TextColor3 = n > 0
			and Color3.fromRGB(40, 120, 255)
			or  Color3.fromRGB(85, 85, 110)
	end
end

local function deleteObject(part)
	if not part or not part.Parent then return end
	if part:IsDescendantOf(char)   then return end
	if part:IsA("Terrain")         then return end
	local data = savePartData(part)
	table.insert(deleteStack, data)
	if #deleteStack > MAX_UNDO then table.remove(deleteStack, 1) end
	part.Parent = nil
	updateUndoLabel()
end

local function undoDelete()
	if #deleteStack == 0 then return end
	local data = table.remove(deleteStack)
	pcall(function()
		data.part.Parent = data.parent
		if data.cframe and data.part:IsA("BasePart") then
			data.part.CFrame = data.cframe
		end
	end)
	updateUndoLabel()
end

local function setDeleteMode(enabled)
	state.DeleteMode = enabled
	if enabled then
		local mouse = plr:GetMouse()
		deleteConn = mouse.Button1Down:Connect(function()
			local target = mouse.Target
			if target then deleteObject(target) end
		end)
	else
		if deleteConn then deleteConn:Disconnect(); deleteConn = nil end
	end
end

UIS.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if input.KeyCode == Enum.KeyCode.Z and state.DeleteMode then
		undoDelete()
	end
end)

