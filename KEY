-- NO MERCY HUB (Modern UI Fixed)

local TweenService = game:GetService("TweenService")
local UIS = game:GetService("UserInputService")

local KEY = "NOMERCY31"

local gui = Instance.new("ScreenGui")
gui.Parent = game.CoreGui
gui.ResetOnSpawn = false

-- MAIN FRAME
local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,340,0,200)
frame.Position = UDim2.new(0.5,-170,0.5,-100)
frame.BackgroundColor3 = Color3.fromRGB(15,15,15)
frame.BorderSizePixel = 0

Instance.new("UICorner",frame).CornerRadius = UDim.new(0,10)

-- TOP BAR
local top = Instance.new("Frame", frame)
top.Size = UDim2.new(1,0,0,30)
top.BackgroundColor3 = Color3.fromRGB(20,20,20)
top.BorderSizePixel = 0

Instance.new("UICorner",top).CornerRadius = UDim.new(0,10)

local title = Instance.new("TextLabel", top)
title.Size = UDim2.new(1,-60,1,0)
title.Position = UDim2.new(0,10,0,0)
title.BackgroundTransparency = 1
title.Text = "NO MERCY HUB"
title.Font = Enum.Font.GothamBold
title.TextColor3 = Color3.fromRGB(0,255,120)
title.TextScaled = true
title.TextXAlignment = Enum.TextXAlignment.Left

-- CLOSE BUTTON
local close = Instance.new("TextButton", top)
close.Size = UDim2.new(0,30,1,0)
close.Position = UDim2.new(1,-30,0,0)
close.Text = "X"
close.Font = Enum.Font.GothamBold
close.TextColor3 = Color3.new(1,1,1)
close.BackgroundColor3 = Color3.fromRGB(150,40,40)

-- MINIMIZE
local minimize = Instance.new("TextButton", top)
minimize.Size = UDim2.new(0,30,1,0)
minimize.Position = UDim2.new(1,-60,0,0)
minimize.Text = "-"
minimize.Font = Enum.Font.GothamBold
minimize.TextColor3 = Color3.new(1,1,1)
minimize.BackgroundColor3 = Color3.fromRGB(40,120,40)

-- CONTENT
local content = Instance.new("Frame", frame)
content.Size = UDim2.new(1,0,1,-30)
content.Position = UDim2.new(0,0,0,30)
content.BackgroundTransparency = 1

-- TEXTBOX
local box = Instance.new("TextBox", content)
box.Size = UDim2.new(0.8,0,0,40)
box.Position = UDim2.new(0.1,0,0.3,0)
box.PlaceholderText = "Enter Key..."
box.BackgroundColor3 = Color3.fromRGB(25,25,25)
box.TextColor3 = Color3.fromRGB(0,255,120)
box.Font = Enum.Font.Gotham
box.TextScaled = true
Instance.new("UICorner",box)

-- BUTTON
local button = Instance.new("TextButton", content)
button.Size = UDim2.new(0.8,0,0,40)
button.Position = UDim2.new(0.1,0,0.6,0)
button.Text = "CONTINUE"
button.BackgroundColor3 = Color3.fromRGB(0,170,80)
button.TextColor3 = Color3.new(1,1,1)
button.Font = Enum.Font.GothamBold
button.TextScaled = true
Instance.new("UICorner",button)

-- DRAG SYSTEM (FIXED)
local dragging = false
local dragStart
local startPos

top.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)

top.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- MINIMIZE FUNCTION
local minimized = false
minimize.MouseButton1Click:Connect(function()
	minimized = not minimized
	content.Visible = not minimized
	frame.Size = minimized and UDim2.new(0,340,0,30) or UDim2.new(0,340,0,200)
end)

-- CLOSE FUNCTION
close.MouseButton1Click:Connect(function()
	gui:Destroy()
end)

-- ANIMATION
frame.BackgroundTransparency = 1
TweenService:Create(frame,TweenInfo.new(0.5),{
	BackgroundTransparency = 0
}):Play()

-- KEY CHECK
button.MouseButton1Click:Connect(function()
	if box.Text == KEY then
		box.Text = "Key Correct!"
	else
		box.Text = "Wrong Key!"
	end
end)
