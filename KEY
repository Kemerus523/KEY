local pages = Instance.new("Frame", frame)
pages.Size = UDim2.new(1,-120,1,-30)
pages.Position = UDim2.new(0,120,0,30)
pages.BackgroundTransparency = 1

-- FUNCTION CREATE PAGE
local function createPage()
	local page = Instance.new("Frame")
	page.Parent = pages
	page.Size = UDim2.new(1,0,1,0)
	page.Visible = false
	page.BackgroundTransparency = 1
	return page
end

-- FUNCTION CREATE TAB
local function createTab(name, order)

	local tab = Instance.new("TextButton", tabs)
	tab.Size = UDim2.new(1,0,0,40)
	tab.Position = UDim2.new(0,0,0,(order-1)*40)
	tab.Text = name
	tab.BackgroundColor3 = Color3.fromRGB(0,170,80)
	tab.TextColor3 = Color3.new(1,1,1)

	local page = createPage()

	tab.MouseButton1Click:Connect(function()

		for _,v in pairs(pages:GetChildren()) do
			if v:IsA("Frame") then
				v.Visible = false
			end
		end

		page.Visible = true
	end)

	return page
end

