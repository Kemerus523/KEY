local function MS_matchTool(n, list)
	for _, v in ipairs(list) do
		if n:find(v, 1, true) then return true end
	end
	return false
end

local function MS_EquipTool(list)
	local ch = plr.Character
	local bp = plr:FindFirstChild("Backpack")
	if not ch then return false end
	for _, o in ipairs(ch:GetChildren()) do
		if o:IsA("Tool") and MS_matchTool(o.Name:lower(), list) then
			return true
		end
	end
	if bp then
		for _, o in ipairs(bp:GetChildren()) do
			if o:IsA("Tool") and MS_matchTool(o.Name:lower(), list) then
				if pcall(function() o.Parent = ch end) then
					task.wait(0.35)
					return true
				end
			end
		end
	end
	return false
end

local function MS_FirePrompt(pr)
	if not pr or not pr.Parent then return end
	MS_patchPr(pr)
	if fireproximityprompt then
		if pcall(function() fireproximityprompt(pr) end) then task.wait(0.18); return end
	end
	if pcall(function() ProximityPromptService:TriggerPrompt(pr) end) then
		task.wait(0.18); return
	end
	pcall(function()
		pr:InputHoldBegin()
		task.wait(0.12)
		pr:InputHoldEnd()
	end)
	task.wait(0.18)
end

local function MS_GetLamontPrompt()
	local ok, r = pcall(function()
		return workspace.Folders.NPCs["Lamont Bell"].UpperTorso.ProximityPrompt
	end)
	if ok and r then return r end
