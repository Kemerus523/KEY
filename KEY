	{name = "Apt RS 1",     cf = CFrame.new(1139, 12,  449)},
}

local function TeleportTo(cf, locationName)
	showLoadingScreen(locationName)
	
	task.spawn(function()
		updateLoadingProgress(0.1, "Mempersiapkan teleport...")
		task.wait(0.3)
		
		updateLoadingProgress(0.25, "Mengecek kendaraan...")
		task.wait(0.2)
		
		pcall(function()
			local ch = plr.Character
			if not ch then return end
			local hm = ch:FindFirstChildOfClass("Humanoid")

			updateLoadingProgress(0.4, "Memproses perpindahan...")
			task.wait(0.2)

			if hm and hm.SeatPart then
				updateLoadingProgress(0.6, "Memindahkan kendaraan...")
				local seat = hm.SeatPart
				local veh  = seat.Parent
				while veh and not veh:IsA("Model") do veh = veh.Parent end
				if veh then
					local root    = veh.PrimaryPart or seat
					local hrpLocal = ch:FindFirstChild("HumanoidRootPart")
					
					for _, p in ipairs(veh:GetDescendants()) do
						if p:IsA("BasePart") then
							pcall(function()
								p.AssemblyLinearVelocity  = Vector3.zero
								p.AssemblyAngularVelocity = Vector3.zero
							end)
						end
					end
					
					local vcf = cf
					if hrpLocal then
						local ok, rel = pcall(function() return root.CFrame:Inverse() * hrpLocal.CFrame end)
						if ok and rel then vcf = cf * rel:Inverse() end
					end
					
					updateLoadingProgress(0.8, "Hampir sampai...")
					task.wait(0.15)
					veh:PivotTo(vcf)
					updateLoadingProgress(1, "✓ Teleport berhasil!")
					task.wait(0.3)
					return
				end
			end

			updateLoadingProgress(0.7, "Memindahkan karakter...")
			task.wait(0.15)
			
			local hrpLocal = ch:FindFirstChild("HumanoidRootPart")
			if hrpLocal then 
				hrpLocal.CFrame = cf 
				updateLoadingProgress(1, "✓ Teleport berhasil!")
				task.wait(0.3)
			end
		end)
		
		task.wait(0.4)
		hideLoadingScreen()
	end)
end

