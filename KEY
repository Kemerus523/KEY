local MS_TIMING = {
	water   = 22,
	sugar   = 1,
	gelatin = 47,
	empty   = 2,
	rest    = 3,
}

local MS_TOOL_NAMES = {
	water   = {"Water","Air","Water Bucket","Bucket of Water","Air Bucket","Water Container","Air Minum"},
	sugar   = {"Sugar Block Bag","Sugar Block","Gula","Sugar Bag","Sugar Sack","Sugar Cube","Gula Block"},
	gelatin = {"Gelatin","Gelatin Bag","Gelatin Block","Gelatin Sack","Gelatin Cube","Agar"},
	empty   = {"EmptyBag","Empty Bag","Empty Back","EmptyBack","Kosong","Empty Sack","Kantong Kosong"},
}

local cookPromptCache  = {}
local cookLastScan     = 0
local running          = false
local cookStatusLabel  = cookStatusLbl  -- diisi saat UI dibuat

local function cookFindNearestPrompt(maxRange)
	local ch = plr.Character
	if not ch then return nil end
	local root = ch:FindFirstChild("HumanoidRootPart")
	if not root then return nil end
	local now = tick()
	if now - cookLastScan > 2 or #cookPromptCache == 0 then
		cookPromptCache = {}
		for _, obj in pairs(workspace:GetDescendants()) do
			if obj:IsA("ProximityPrompt") then
				table.insert(cookPromptCache, obj)
			end
		end
		cookLastScan = now
	end
	local playerPos   = root.Position
	local nearest     = nil
	local nearestDist = maxRange or 50
	for _, prompt in ipairs(cookPromptCache) do
		if prompt.Enabled then
			local parent    = prompt.Parent
			local promptPos = nil
			if parent and parent:IsA("BasePart") then
				promptPos = parent.Position
			elseif parent and parent:IsA("Attachment") then
				promptPos = parent.WorldPosition
			end
			if promptPos then
				local dist = (promptPos - playerPos).Magnitude
				if dist <= (maxRange or prompt.MaxActivationDistance) and dist < nearestDist then
					nearestDist = dist
					nearest     = prompt
				end
			end
		end
	end
	return nearest
end

local function cookTriggerPrompt(prompt)
	if not prompt then return false end
	local ok = pcall(function()
		prompt:InputHoldBegin()
		task.wait(prompt.HoldDuration + 0.1)
		prompt:InputHoldEnd()
	end)
	return ok
end

local function cookScanTool(nameList)
	local bp   = plr:FindFirstChild("Backpack")
	local ch   = plr.Character
	local locs = {}
	if bp then table.insert(locs, bp) end
	if ch then table.insert(locs, ch) end
	for _, container in ipairs(locs) do
		for _, obj in ipairs(container:GetChildren()) do
			if obj:IsA("Tool") then
				for _, targetName in ipairs(nameList) do
					if string.find(string.lower(obj.Name), string.lower(targetName), 1, true) then
						return obj, (container == ch)
					end
				end
			end
		end
	end
	return nil, false
end

local function cookEquipTool(nameList)
	local tool, equipped = cookScanTool(nameList)
	if not tool then return false end
	if equipped then return true end
	pcall(function() tool.Parent = plr.Character end)
	task.wait(0.3)
	return true
end

local function cookSetStatus(txt, color)
	if cookStatusLabel then
		cookStatusLabel.Text       = txt
		cookStatusLabel.TextColor3 = color or C.MUTED
	end
end

local function mainLoop()
	while running do
		-- WATER
		cookSetStatus("🚿 Menuang air...", C.ACCENT)
		if not cookEquipTool(MS_TOOL_NAMES.water) then task.wait(2); continue end
		task.wait(0.3)
		local p = cookFindNearestPrompt(10)
		if p then cookTriggerPrompt(p) end
		for i = 1, MS_TIMING.water do
			if not running then break end
			cookSetStatus("🚿 Air... " .. (MS_TIMING.water - i) .. "s", C.ACCENT)
			task.wait(1)
		end
		if not running then break end

		-- SUGAR
		cookSetStatus("🍬 Menuang gula...", C.ORANGE)
		if not cookEquipTool(MS_TOOL_NAMES.sugar) then task.wait(2); continue end
		task.wait(0.3)
		p = cookFindNearestPrompt(10)
		if p then cookTriggerPrompt(p) end
		for i = 1, MS_TIMING.sugar do
			if not running then break end
			task.wait(1)
		end
		if not running then break end

		-- GELATIN
		cookSetStatus("🟡 Menuang gelatin...", C.COOK_CLR)
		if not cookEquipTool(MS_TOOL_NAMES.gelatin) then task.wait(2); continue end
		task.wait(0.3)
		p = cookFindNearestPrompt(10)
		if p then cookTriggerPrompt(p) end
		for i = 1, MS_TIMING.gelatin do
			if not running then break end
			cookSetStatus("🟡 Gelatin... " .. (MS_TIMING.gelatin - i) .. "s", C.COOK_CLR)
			task.wait(1)
		end
		if not running then break end

		-- EMPTY BAG
		cookSetStatus("🛍️ Kantong kosong...", C.MUTED)
		if cookEquipTool(MS_TOOL_NAMES.empty) then
			task.wait(0.3)
			p = cookFindNearestPrompt(10)
			if p then cookTriggerPrompt(p) end
			for i = 1, MS_TIMING.empty do
				if not running then break end
				task.wait(1)
			end
		end
		if not running then break end

		-- REST
		cookSetStatus("✅ Siklus selesai! Istirahat...", C.SUCCESS)
		for i = 1, MS_TIMING.rest do
			if not running then break end
			task.wait(1)
		end
	end
	cookSetStatus("⏹ Auto Masak: OFF", C.MUTED)
end

