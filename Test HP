-- Function to Create Tab Button
local function CreateTabButton(tabData, index)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1, 0, 0, 45)
    button.Position = UDim2.new(0, 0, 0, (index - 1) * 50)
    button.BackgroundColor3 = COLORS.Secondary
    button.BorderSizePixel = 0
    button.Text = ""
    button.AutoButtonColor = false
    button.Parent = Sidebar
    CreateUICorner(8).Parent = button
    
    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(0, 25, 0, 25)
    icon.Position = UDim2.new(0, 12, 0.5, -12)
    icon.BackgroundTransparency = 1
    icon.Text = tabData.Icon
    icon.Font = Enum.Font.GothamBold
    icon.TextSize = 18
    icon.TextColor3 = COLORS.TextDim
    icon.Parent = button
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -50, 1, 0)
    label.Position = UDim2.new(0, 45, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = tabData.Name
    label.Font = Enum.Font.GothamMedium
    label.TextSize = 13
    label.TextColor3 = COLORS.TextDim
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = button
    
    -- Selection Indicator
    local indicator = Instance.new("Frame")
    indicator.Size = UDim2.new(0, 3, 0, 0)
    indicator.Position = UDim2.new(0, 0, 0.5, 0)
    indicator.AnchorPoint = Vector2.new(0, 0.5)
    indicator.BackgroundColor3 = COLORS.Accent
    indicator.BorderSizePixel = 0
    indicator.Parent = button
    CreateUICorner(2).Parent = indicator
    
    TabButtons[tabData.Name] = {
        Button = button,
        Icon = icon,
        Label = label,
        Indicator = indicator
    }
    
    button.MouseEnter:Connect(function()
        if SelectedTab ~= tabData.Name then
            TweenObject(button, {BackgroundColor3 = Color3.fromRGB(35, 35, 45)}, 0.2)
        end
    end)
    
    button.MouseLeave:Connect(function()
        if SelectedTab ~= tabData.Name then
            TweenObject(button, {BackgroundColor3 = COLORS.Secondary}, 0.2)
        end
    end)
    
    button.MouseButton1Click:Connect(function()
        SelectTab(tabData.Name)
    end)
end

