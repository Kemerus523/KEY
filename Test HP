    if key == "" then
        ShowNotification("Please enter a key!", false)
        return
    end
    
    if ValidateKey(key) then
        ShowNotification("Key validated! Loading...", true)
        
        task.wait(0.5)
        
        -- Hide key frame
        TweenObject(KeyFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        
        task.wait(0.3)
        KeyFrame.Visible = false
        
        -- Show main frame
        MainFrame.Size = UDim2.new(0, 0, 0, 0)
        MainFrame.Visible = true
        TweenObject(MainFrame, {Size = UDim2.new(0, CONFIG.DefaultSize.X, 0, CONFIG.DefaultSize.Y)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        
        -- Select first tab
        task.wait(0.2)
        SelectTab("Combat")
    else
        ShowNotification("Invalid key! Try again.", false)
        KeyInputBox.Text = ""
    end
end)

