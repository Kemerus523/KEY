-- DRAGGING SYSTEM
local dragging = false
local dragInput, dragStart, startPos

local function updateDrag(input)
    if not dragging then return end
    local success, err = pcall(function()
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end)
    if not success then
        dragging = false
    end
end

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateDrag(input)
    end
end)

-- RESIZE SYSTEM
local resizing = false
local resizeStart, resizeStartSize

local function updateResize(input)
    if not resizing then return end
    local success, _ = pcall(function()
        local delta = input.Position - resizeStart
        local newWidth = math.clamp(resizeStartSize.X + delta.X, CONFIG.MinSize.X, CONFIG.MaxSize.X)
        local newHeight = math.clamp(resizeStartSize.Y + delta.Y, CONFIG.MinSize.Y, CONFIG.MaxSize.Y)
        MainFrame.Size = UDim2.new(0, newWidth, 0, newHeight)
    end)
    if not success then
        resizing = false
    end
end

ResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        resizing = true
        resizeStart = input.Position
        resizeStartSize = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        updateResize(input)
    end
end)

ResizeHandle.MouseEnter:Connect(function()
    TweenObject(ResizeHandle, {Size = UDim2.new(0, 25, 0, 25)}, 0.2)
    TweenObject(ResizeHandle, {BackgroundColor3 = Color3.fromRGB(55, 150, 255)}, 0.2)
end)

ResizeHandle.MouseLeave:Connect(function()
    if not resizing then
        TweenObject(ResizeHandle, {Size = UDim2.new(0, 20, 0, 20)}, 0.2)
        TweenObject(ResizeHandle, {BackgroundColor3 = COLORS.Accent}, 0.2)
    end
end)

-- HIDE/SHOW SYSTEM
local isHidden = false
local savedSize = Vector2.new(CONFIG.DefaultSize.X, CONFIG.DefaultSize.Y)

local function ToggleGUI()
    isHidden = not isHidden
    if isHidden then
        savedSize = Vector2.new(MainFrame.Size.X.Offset, MainFrame.Size.Y.Offset)
        TweenObject(MainFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3)
        MainFrame.Visible = false

        FloatingHideButton.Visible = true
        TweenObject(FloatingHideButton, {Size = UDim2.new(0, 50, 0, 50)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    else
        TweenObject(FloatingHideButton, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.3)
        FloatingHideButton.Visible = false

        MainFrame.Visible = true
        TweenObject(MainFrame, {Size = UDim2.new(0, savedSize.X, 0, savedSize.Y)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end
end

HideButton.MouseButton1Click:Connect(ToggleGUI)
FloatingHideButton.MouseButton1Click:Connect(ToggleGUI)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.K then
        if MainFrame.Visible or FloatingHideButton.Visible then
            ToggleGUI()
        end
    end
end)

-- Floating Button Drag
local floatingDragging = false
local floatingDragStart, floatingStartPos

FloatingHideButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        floatingDragging = true
        floatingDragStart = input.Position
        floatingStartPos = FloatingHideButton.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if floatingDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        pcall(function()
            local delta = input.Position - floatingDragStart
            FloatingHideButton.Position = UDim2.new(
                floatingStartPos.X.Scale,
                floatingStartPos.X.Offset + delta.X,
                floatingStartPos.Y.Scale,
                floatingStartPos.Y.Offset + delta.Y
            )
        end)
    end
end)

